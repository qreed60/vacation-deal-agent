# Phase 3 source configuration

# Existing local SearXNG instance.
SEARXNG_BASE_URL=http://127.0.0.1:8888
SEARXNG_TIMEOUT_SECONDS=5

# Amadeus Self-Service / test environment.
AMADEUS_BASE_URL=https://test.api.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENABLED=false
AMADEUS_TIMEOUT_SECONDS=8

# Google Places API.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_ENABLED=false
GOOGLE_PLACES_TIMEOUT_SECONDS=8

# SerpAPI Google Flights / Google Hotels.
SERPAPI_ENABLED=false
SERPAPI_API_KEY=
SERPAPI_BASE_URL=https://serpapi.com/search
SERPAPI_TIMEOUT_SECONDS=8

# Optional free/unofficial flight source. Disabled by default.
FAST_FLIGHTS_ENABLED=false
FAST_FLIGHTS_FETCH_MODE=common
FAST_FLIGHTS_SEAT=economy
FAST_FLIGHTS_MAX_STOPS=
FAST_FLIGHTS_MAX_RESULTS=20

# Result bounding for fast-flights: maximum number of priced flight snapshots
# created per source run. Deduplication is applied before limiting.

# Optional free/no-key trvl structured flight and hotel source. Disabled by default.
TRVL_ENABLED=false
TRVL_BINARY_PATH=.tools/trvl/trvl
TRVL_TIMEOUT_SECONDS=120
TRVL_MAX_FLIGHT_RESULTS=20
TRVL_MAX_HOTEL_RESULTS=20
TRVL_CURRENCY=USD

# Optional Phase 3/4 free-source probe hooks. These are not production sources.
# Commands must be local, read-only, short-lived, and return structured JSON on stdout.
FREE_TRAVEL_PROBE_FLIGHTS_SKILL_COMMAND=
FREE_TRAVEL_PROBE_TRAVEL_HACKING_TOOLKIT_COMMAND=
